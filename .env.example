# ─── Database ─────────────────────────────────────────────────────────
# Automatically configured when using Docker Compose.
# Override only if using an external PostgreSQL instance.
DATABASE_URL=postgresql://ares:ares_secret@localhost:5432/ares_db

# ─── Telegram ─────────────────────────────────────────────────────────
# Get API credentials from: https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=                 # Integer — REQUIRED for ALPHA agent
TELEGRAM_API_HASH=               # 32-char hex — REQUIRED for ALPHA agent
TELEGRAM_PHONE=                  # Your phone number with country code e.g. +1234567890

# ─── Ollama LLM ───────────────────────────────────────────────────────
# Install: https://ollama.com/download
# Then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── NASA FIRMS ───────────────────────────────────────────────────────
# Free key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=                   # REQUIRED for thermal fusion validation

# ─── ADSB.lol ─────────────────────────────────────────────────────────
# Free, keyless community API for unfiltered military ADS-B data.
# Default value is correct; no registration or payment needed.
ADSB_LOL_BASE_URL=https://api.adsb.lol/v2

# ─── Copernicus / Sentinel-2 ──────────────────────────────────────────
# Register free at: https://dataspace.copernicus.eu/
COPERNICUS_USERNAME=             # Your CDSE account email
COPERNICUS_PASSWORD=             # Your CDSE account password
COPERNICUS_CLIENT_ID=cdse-public # Default public client ID

# ─── MarineTraffic (optional — commercial contract required) ──────────
# Contact: https://www.kpler.com/maritime or use AISHub as free alternative
MARINETRAFFIC_API_KEY=           # Leave blank to disable AIS tracking

# ─── Broadcastify (optional) ──────────────────────────────────────────
BROADCASTIFY_API_KEY=            # Leave blank to disable

# ─── ACLED (Armed Conflict Location & Event Data) ─────────────────────
# Free registration at: https://acleddata.com/register/ (instant approval)
# Both key AND email are required in every API request.
ACLED_API_KEY=                   # Your ACLED API key
ACLED_EMAIL=                     # Email used to register for ACLED
ACLED_BASE_URL=https://api.acleddata.com/acled/read
ACLED_MAX_RECORDS=200            # Events per poll cycle
ACLED_POLL_INTERVAL=3600         # Seconds between polls (default: 1 hour)
ACLED_RELIABILITY_ALPHA=0.80     # DST source weight (0.0–1.0)

# ─── UCDP (Uppsala Conflict Data Program) ─────────────────────────────
# No API key required — open academic dataset.
# https://ucdp.uu.se/apidocs/
UCDP_BASE_URL=https://ucdpapi.pcr.uu.se/api/gedevents/24.1
UCDP_POLL_INTERVAL=7200          # Seconds between polls (default: 2 hours)
UCDP_MAX_RECORDS=100             # Events per page request
UCDP_LOOKBACK_DAYS=30            # Days back to query for new events
UCDP_RELIABILITY_ALPHA=0.78      # DST source weight (0.0–1.0)

# ─── NGA Maritime Safety Information ──────────────────────────────────
# No API key required — official US government data.
# https://msi.gs.mil/
NGA_BASE_URL=https://msi.gs.mil/api/publications/broadcast-warn
NGA_POLL_INTERVAL=1800           # Seconds between polls (default: 30 minutes)

# ─── WebSocket ────────────────────────────────────────────────────────
VITE_WS_URL=ws://localhost:8000/ws/events

# ─── Agent Feature Flags ──────────────────────────────────────────────
ENABLE_TELEGRAM=false
ENABLE_RSS=true
ENABLE_GDELT=true
ENABLE_ADSB=true
ENABLE_FIRMS=true
ENABLE_SENTINEL=true
ENABLE_WEBSDR=false
ENABLE_MARINE=false
ENABLE_ACLED=false               # Requires ACLED_API_KEY + ACLED_EMAIL
ENABLE_UCDP=true                 # No key required
ENABLE_NGA=true                  # No key required

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
