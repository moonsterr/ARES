# ─── Database ─────────────────────────────────────────────────────────
# Automatically configured when using Docker Compose.
# Override only if connecting to an external PostgreSQL instance.
DATABASE_URL=postgresql://ares:ares_secret@localhost:5432/ares_db

# ─── Telegram ─────────────────────────────────────────────────────────
# Get credentials from: https://my.telegram.org → API Development Tools
# Required only for the ALPHA agent (ENABLE_TELEGRAM=true).
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# ─── Ollama LLM ───────────────────────────────────────────────────────
# Ollama must run on the HOST (not in Docker) for GPU access.
# Install: https://ollama.ai  |  Then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── NASA FIRMS ───────────────────────────────────────────────────────
# Free key from: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Required for thermal hotspot fusion and strike verification.
FIRMS_MAP_KEY=

# ─── ADSB.lol ─────────────────────────────────────────────────────────
# Free, keyless API — no changes needed.
ADSB_LOL_BASE_URL=https://api.adsb.lol/v2

# ─── Copernicus / Sentinel-2 ──────────────────────────────────────────
# Free account at: https://dataspace.copernicus.eu/
# Required for post-strike satellite imagery (BRAVO-C agent).
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
COPERNICUS_CLIENT_ID=cdse-public

# ─── MarineTraffic (optional — commercial contract required) ──────────
# Leave blank to disable AIS vessel tracking.
MARINETRAFFIC_API_KEY=

# ─── Broadcastify (optional) ──────────────────────────────────────────
BROADCASTIFY_API_KEY=

# ─── ACLED (Armed Conflict Location & Event Data) ─────────────────────
# Register free at: https://acleddata.com/register/
# ACLED uses OAuth2 password-grant auth — email + password are required.
# After registering, request API data access from your account dashboard.
ACLED_EMAIL=
ACLED_PASSWORD=
ACLED_TOKEN_URL=https://acleddata.com/oauth/token
ACLED_BASE_URL=https://acleddata.com/api/acled/read
ACLED_MAX_RECORDS=200
ACLED_POLL_INTERVAL=3600
ACLED_RELIABILITY_ALPHA=0.80

# ─── UCDP (Uppsala Conflict Data Program) ─────────────────────────────
# Access token required — register at: https://ucdpapi.pcr.uu.se
UCDP_ACCESS_TOKEN=
UCDP_BASE_URL=https://ucdpapi.pcr.uu.se/api/gedevents/24.1
UCDP_POLL_INTERVAL=7200
UCDP_MAX_RECORDS=100
UCDP_LOOKBACK_DAYS=30
UCDP_RELIABILITY_ALPHA=0.78

# ─── NGA Maritime Safety Information ──────────────────────────────────
# NOTE: msi.gs.mil is geo-blocked outside the US.
# Set ENABLE_NGA=false if you are not behind a US IP.
NGA_BASE_URL=https://msi.gs.mil/api/publications/broadcast-warn
NGA_POLL_INTERVAL=1800

# ─── WebSocket / Frontend ─────────────────────────────────────────────
VITE_WS_URL=ws://localhost:8000/ws/events

# ─── Agent Feature Flags ──────────────────────────────────────────────
ENABLE_TELEGRAM=false
ENABLE_RSS=true
ENABLE_GDELT=true
ENABLE_ADSB=true
ENABLE_FIRMS=true
ENABLE_SENTINEL=true
ENABLE_WEBSDR=false
ENABLE_MARINE=false
ENABLE_ACLED=true
ENABLE_UCDP=true
ENABLE_NGA=false

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
